# ==========================================
# OPC Platform — 环境变量模板
# 本地: cp .env.example .env
# 生产: 填入真实值后 docker compose up -d
# ==========================================

# ========== 数据库 ==========
DATABASE_URL=postgresql+asyncpg://opc_user:YOUR_DB_PASSWORD@postgres:5432/opc_platform
DATABASE_URL_SYNC=postgresql://opc_user:YOUR_DB_PASSWORD@postgres:5432/opc_platform
POSTGRES_DB=opc_platform
POSTGRES_USER=opc_user
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0

# ========== JWT (生成: python -c "import secrets; print(secrets.token_urlsafe(32))") ==========
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ========== LLM / AI (支持 OpenAI 兼容 API) ==========
# 国内推荐: DeepSeek / 通义千问 / 文心一言 / Moonshot / 智谱
LLM_PROVIDER=deepseek
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro
EMBEDDING_MODEL=text-embedding-3-small

# ========== 端口 (可选) ==========
API_PORT=8000
WEB_PORT=3000
PG_PORT=5432
REDIS_PORT=6379

# ========== 邮件 (可选) ==========
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ========== 阿里云 OSS (可选) ==========
OSS_PROVIDER=aliyun
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=opc-uploads
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# ========== 应用 ==========
APP_ENV=production
APP_DEBUG=false
CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]
