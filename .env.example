# ==========================================
# OPC Platform — 环境变量模板
# 复制此文件为 .env 并填入真实值
# ==========================================

# ========== 数据库 ==========
DATABASE_URL=postgresql+asyncpg://opc_user:YOUR_DB_PASSWORD@localhost:5432/opc_platform
DATABASE_URL_SYNC=postgresql://opc_user:YOUR_DB_PASSWORD@localhost:5432/opc_platform

# ========== Redis ==========
REDIS_URL=redis://localhost:6379/0

# ========== JWT (生产环境必须用随机字符串) ==========
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=生成随机密钥填入此处
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== LLM / AI ==========
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ========== 第三方搜索 (可选) ==========
SEARCH_API_KEY=
SEARCH_API_BASE_URL=

# ========== 飞书告警 (可选) ==========
FEISHU_WEBHOOK_URL=

# ========== 应用 ==========
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
